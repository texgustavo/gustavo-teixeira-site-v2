# =============================================================================
# .env.example — required + optional env vars for the agent endpoint.
# Copy to .env.local for dev. On Vercel, set these in Project → Settings → Env.
# =============================================================================

# -------- REQUIRED -----------------------------------------------------------
# Anthropic API key. Provider used by api/agent.ts (Claude Haiku 4.5).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# -------- OPTIONAL (RECOMMENDED for max security in production) -------------
# Upstash Redis — enables persistent rate limit (L2), event logging (L7),
# and the hard daily cost cap (L8). Without these, L2 falls back to an
# in-memory limiter (8 req/min per fingerprint, per edge instance) and
# L8 is effectively disabled.
#
# Create a free Upstash Redis DB at https://console.upstash.com/redis
# → Copy the "UPSTASH_REDIS_REST_URL" and "UPSTASH_REDIS_REST_TOKEN" values.
UPSTASH_REDIS_REST_URL=https://xxx-yyy-12345.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Random string used to salt the SHA-256 hash of (IP + User-Agent) before it's
# stored in Redis keys / logs. Generate with `openssl rand -hex 32` or any
# password manager. Required for privacy when Upstash is enabled.
IP_HASH_SECRET=replace-with-32-random-bytes-hex

# Override the hard daily cost ceiling (USD). Default = 1 ($1/day across all
# users). Once exceeded the endpoint returns 503 until midnight UTC.
AGENT_DAILY_COST_USD=1
